---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { CATEGORIES, type Category } from '@/content.config';
import { SITE_ORIGIN, SITE_URL, blogPath } from '@/lib/site';

// Solo se generan páginas para categorías CON contenido — una categoría
// vacía sería thin content. Cuando una categoría recibe su primer post,
// la página aparece sola en el próximo build.
export async function getStaticPaths() {
  const posts = await getCollection('blog', (e) => !e.data.draft);
  const active = CATEGORIES.filter((cat) =>
    posts.some((p) => p.data.category === cat.label)
  );
  return active.map((cat) => ({
    params: { slug: cat.slug },
    props: {
      cat,
      posts: posts.filter((p) => p.data.category === cat.label),
      activeSlugs: active.map((c) => c.slug),
    },
  }));
}

const { cat, posts, activeSlugs } = Astro.props as {
  cat: Category;
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
  activeSlugs: string[];
};

const sorted = [...posts].sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const title = `${cat.label} | Blog ProFactur`;
const description = `Artículos sobre ${cat.label.toLowerCase()} en el blog de ProFactur: guías prácticas y actualidad para facturar sin errores.`;
const canonical = `${SITE_URL}/categoria/${cat.slug}`;

const activeCategories = CATEGORIES.filter((c) => activeSlugs.includes(c.slug));

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ProFactur', item: SITE_ORIGIN },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: SITE_URL },
    { '@type': 'ListItem', position: 3, name: cat.label, item: canonical },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="mx-auto max-w-[1100px] px-5 pt-16 pb-10 md:pt-20">
    <nav aria-label="Migas" class="mb-5 text-[0.75rem] uppercase tracking-widest" style="color: var(--c-muted);">
      <a href={SITE_ORIGIN} class="no-underline transition-colors hover:text-[var(--color-primary)]" style="color: var(--c-muted);">ProFactur</a>
      <span aria-hidden="true" class="mx-2 opacity-50">/</span>
      <a href={blogPath()} class="no-underline transition-colors hover:text-[var(--color-primary)]" style="color: var(--c-muted);">Blog</a>
      <span aria-hidden="true" class="mx-2 opacity-50">/</span>
      <span aria-current="page">{cat.label}</span>
    </nav>

    <span class:list={['cat-badge mb-4', cat.badge]}>{cat.label}</span>
    <h1
      class="m-0 font-extrabold tracking-tight"
      style="font-size: clamp(1.8rem, 4vw, 2.6rem); line-height: 1.15; letter-spacing: -0.02em;"
    >
      {cat.label}
    </h1>
    <p class="mt-4 max-w-[620px] text-[1rem] leading-relaxed" style="color: var(--c-muted);">
      {sorted.length} {sorted.length === 1 ? 'artículo' : 'artículos'} en esta categoría.
    </p>
  </section>

  <section class="mx-auto max-w-[1100px] px-5 pb-20" aria-label={`Artículos de ${cat.label}`}>
    <nav aria-label="Categorías" class="mb-10">
      <ul class="m-0 flex list-none flex-wrap items-center gap-2 p-0">
        <li><a href={blogPath()} class="filter-pill">Todas</a></li>
        {
          activeCategories.map((c) => (
            <li>
              <a
                href={blogPath(`/categoria/${c.slug}`)}
                class="filter-pill"
                aria-current={c.slug === cat.slug ? 'page' : undefined}
              >
                {c.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <ul class="m-0 grid list-none grid-cols-1 gap-6 p-0 md:grid-cols-2 lg:grid-cols-3">
      {
        sorted.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
