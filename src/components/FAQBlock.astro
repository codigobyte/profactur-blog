---
/**
 * Bloque de preguntas frecuentes del artículo + JSON-LD FAQPage.
 * Las FAQs vienen del frontmatter (campo `faqs`) — es el contenido que más
 * citan los motores de IA (COD-230, extra #7).
 */
export interface Props {
  faqs: { q: string; a: string }[];
}

const { faqs } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

{
  faqs.length > 0 && (
    <section aria-labelledby="faq-heading" class="mt-14">
      <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
      <h2 id="faq-heading" class="mb-5 text-[1.4rem] font-bold tracking-tight">
        Preguntas frecuentes
      </h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="card group !rounded-[12px] p-0" style="backdrop-filter: none;">
            <summary class="cursor-pointer list-none px-5 py-4 text-[0.98rem] font-semibold marker:hidden [&::-webkit-details-marker]:hidden">
              <span class="flex items-center justify-between gap-3">
                {f.q}
                <span
                  aria-hidden="true"
                  class="text-[var(--color-primary)] transition-transform group-open:rotate-45"
                >
                  +
                </span>
              </span>
            </summary>
            <p class="m-0 px-5 pb-5 text-[0.95rem] leading-relaxed" style="color: var(--c-muted);">
              {f.a}
            </p>
          </details>
        ))}
      </div>
    </section>
  )
}
