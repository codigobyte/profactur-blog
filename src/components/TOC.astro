---
import type { MarkdownHeading } from 'astro';

/**
 * Tabla de contenidos generada desde headings[] de render() — sin rehype-toc.
 * Solo se renderiza en artículos largos (el umbral lo decide la página).
 * Los anchors los garantiza rehype-slug (astro.config.mjs).
 */
export interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length >= 3 && (
    <nav
      aria-label="Tabla de contenidos"
      class="card mb-10 !bg-[var(--c-card-solid)] p-6"
      style="backdrop-filter: none;"
    >
      <p class="m-0 mb-3 text-[0.75rem] font-semibold uppercase tracking-widest" style="color: var(--c-muted);">
        En este artículo
      </p>
      <ol class="m-0 list-none space-y-1.5 p-0 text-[0.92rem]">
        {items.map((h) => (
          <li class:list={[h.depth === 3 && 'pl-4']}>
            <a
              href={`#${h.slug}`}
              class="no-underline transition-colors hover:text-[var(--color-primary-light)]"
              style="color: var(--c-text);"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
