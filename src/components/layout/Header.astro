---
import { SITE_ORIGIN, blogPath } from '@/lib/site';

// Mismos destinos que el nav del chrome marketing (COD-243) — el blog es un
// sitio Astro aparte pero tiene que sentirse el mismo producto. Los anchors
// de sección de la home (Beneficios/Funciones/FAQ) no se replican acá para
// mantener el header del blog compacto.
const navLinks = [
  { label: 'Inicio', href: SITE_ORIGIN },
  { label: 'Aplicaciones', href: `${SITE_ORIGIN}/aplicaciones` },
  { label: 'Precios', href: `${SITE_ORIGIN}/precios` },
  { label: 'Docs', href: `${SITE_ORIGIN}/docs` },
];
---

<header
  class="sticky top-0 z-50 border-b border-[var(--c-line)] backdrop-blur-xl"
  style="background: var(--c-card);"
>
  <div class="mx-auto flex max-w-[1100px] items-center justify-between gap-4 px-5 py-3.5">
    <a
      href={blogPath()}
      class="flex items-center gap-2.5 no-underline"
      aria-label="Blog de ProFactur"
    >
      {/* El logo ya contiene el wordmark ProFactur — solo sumamos "Blog". */}
      <img
        src={blogPath('/images/logo.png')}
        alt="ProFactur"
        width="140"
        height="32"
        class="h-8 w-auto"
      />
      <span class="gradient-text text-[1.15rem]">Blog</span>
    </a>

    <nav aria-label="Principal" class="flex items-center gap-2 sm:gap-5">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="hidden text-[0.9rem] no-underline transition-colors hover:text-[var(--c-text)] md:inline"
            style="color: color-mix(in oklab, var(--c-text) 70%, transparent);"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`${SITE_ORIGIN}/login`}
        class="btn btn-ghost hidden !px-4 !py-2 text-[0.85rem] sm:inline-flex"
      >
        Iniciar sesión
      </a>
      <a
        href={`${SITE_ORIGIN}/registro`}
        class="btn btn-primary !px-4 !py-2 text-[0.85rem]"
      >
        Probar gratis
      </a>
    </nav>
  </div>
</header>
